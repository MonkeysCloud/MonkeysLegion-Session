{
  "name": "monkeyscloud/monkeyslegion-session",
  "type": "library",
  "license": "MIT",
  "require": {
    "php": "^8.4",
    "psr/http-message": "^2.0",
    "psr/http-server-middleware": "^1.0",
    "psr/http-server-handler": "^1.0"
  },
  "autoload": {
    "psr-4": {
      "MonkeysLegion\\Session\\": "src/",
      "MonkeysLegion\\Database\\": "../database/src/",
      "MonkeysLegion\\Query\\": "../query/src/",
      "MonkeysLegion\\Core\\": "../core/src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "MonkeysLegion\\Session\\Tests\\": "tests/"
    }
  },
  "require-dev": {
    "phpstan/phpstan": "^2.1",
    "phpunit/phpunit": "^13.1@dev"
  }
}
