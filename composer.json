{
  "name": "monkeyscloud/monkeyslegion-session",
  "type": "library",
  "license": "MIT",
  "autoload": {
    "psr-4": {
      "MonkeysLegion\\Session\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "MonkeysLegion\\Session\\Tests\\": "tests/"
    }
  },
  "minimum-stability": "dev",
  "require": {
    "php": "^8.4",
    "monkeyscloud/monkeyslegion-core": "^2.0",
    "monkeyscloud/monkeyslegion-database": "^2.0",
    "monkeyscloud/monkeyslegion-query": "^2.0",
    "monkeyscloud/monkeyslegion-cli": "^2.0",
    "psr/http-message": "^2.0",
    "psr/http-server-middleware": "^1.0",
    "psr/http-server-handler": "^1.0"
  },
  "extra": {
    "branch-alias": {
      "dev-main": "1.0.x-dev"
    }
  },
  "require-dev": {
    "monkeyscloud/monkeyslegion-mlc": "^3.0@dev",
    "phpstan/phpstan": "^2.1",
    "phpunit/phpunit": "^13.1@dev"
  }
}
